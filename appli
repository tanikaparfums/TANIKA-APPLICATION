        <input type="text" id="a-nom" placeholder="Ex. : Paradoxe">
        <label for="a-marque">Marque</label>
        <input type="text" id="a-marque" placeholder="Ex. : Prada">
        <label for="a-code">Code-barres (facultatif, pour le scan)</label>
        <input type="number" id="a-code" placeholder="Ex. : 3614273760980">
        <label for="a-bovis">Taux vibratoire (Bovis / U.B.)</label>
        <input type="number" id="a-bovis" placeholder="Ex. : 10800">
        <label for="a-famille">Famille olfactive</label>
        <input type="text" id="a-famille" placeholder="Ex. : Floral musqué">
        <label for="a-chakra">Point de résonance</label>
        <select id="a-chakra">
          <option value="0">Racine</option>
          <option value="1">Sacré</option>
          <option value="2">Plexus solaire</option>
          <option value="3" selected>Cœur</option>
          <option value="4">Gorge</option>
          <option value="5">Troisième œil</option>
          <option value="6">Couronne</option>
        </select>
        <label for="a-pourquoi">Pourquoi il vibre (ou non)</label>
        <textarea id="a-pourquoi" placeholder="Ce que cette fragrance soutient énergétiquement…"></textarea>
        <label>Compatible avec les intentions</label>
        <div class="chips" id="a-intentions"></div>
        <label>Moment idéal pour le porter</label>
        <div class="chips" id="a-moments"></div>
        <label for="a-oracle">Message oracle (carte d'inspiration)</label>
        <textarea id="a-oracle" placeholder="Une phrase inspirante associée à ce parfum…"></textarea>
        <button class="bouton-or" id="btn-ajouter">Ajouter au répertoire</button>
        </div>
      </details>

      <p class="pied-signature">✦ <span class="or">Tanika Parfums</span> · par Nossane ✦</p>
    </div>

    <!-- ======= JOURNAL ======= -->
