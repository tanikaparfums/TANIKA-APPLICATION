/* ============ ARTICLES ============ */
function formatDateArticle(iso){try{return new Date(iso).toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'});}catch(e){return iso;}}
function afficherArticles(){
  const zone=$('#liste-articles');
  if(!articles.length){
    zone.innerHTML='<p class="vide">Aucun article publié pour l\'instant.<br>Nossane prépare ses premières guidances. ✦</p>';
    return;
  }
  const tries=[...articles].sort((a,b)=>new Date(b.date)-new Date(a.date));
  zone.innerHTML = tries.map((a)=>{
    const i = articles.indexOf(a);
    return `<div class="article" data-i="${i}">
      <div class="art-tete">
        <div>
          <div class="art-cat">${a.categorie}</div>
          <div class="art-titre">${a.titre}</div>
          <div class="art-meta">par Nossane · ${formatDateArticle(a.date)}</div>
        </div>
        ${estAdmin?`<button class="suppr-art" data-i="${i}" aria-label="Supprimer l'article">✕</button>`:''}
      </div>
      <div class="art-corps"><div class="art-texte">${a.texte}</div></div>
    </div>`;
  }).join('');
  zone.querySelectorAll('.article').forEach(el=>{
    el.addEventListener('click',(ev)=>{
      if(ev.target.classList.contains('suppr-art')) return;
      el.classList.toggle('ouvert');
    });
  });
  zone.querySelectorAll('.suppr-art').forEach(b=>{
    b.addEventListener('click',async(ev)=>{
      ev.stopPropagation();
      const art = articles[Number(b.dataset.i)];
      if(art.id) await supabaseClient.from('articles').delete().eq('id',art.id);
      await chargerDonneesPubliques();
    });
  });
}
