/* ============ CHATBOT GUIDE TANIKA ============ */
const SYSTEME_CHAT = `Tu es le Guide Tanika, l'assistant conversationnel de Tanika Parfums, une maison de parfumerie énergétique fondée par Nossane, Prêtresse Alchimiste et pionnière de la parfumerie vibratoire.

Ce que propose Tanika :
- Le Scan Olfactif : une lecture vibratoire au pendule qui révèle la famille olfactive de résonance d'une personne.
- La Précommande de Parfum Personnalisé : une fragrance composée à partir de cette lecture.
- La Séance de Guidance Vibratoire (visio) : environ 60 minutes, lecture au pendule, Décrets de Libération et d'Activation proclamés en direct, synthèse envoyée sous 24h.
- L'Olfactothèque (cette application) : scan de parfums du commerce pour connaître leur fréquence vibratoire, classeur, journal, articles, mantras.

Consignes de ton :
- Tutoie la personne, ton chaleureux, clair, un peu poétique mais jamais confus.
- Réponses courtes (3-5 phrases maximum), adaptées à un chat mobile.
- Ne donne JAMAIS de prix précis (ils peuvent avoir changé), invite à consulter le site ou réserver pour connaître les tarifs actuels.
- Termine tes réponses, quand c'est pertinent, en invitant à visiter tanikaparfums.fr ou à utiliser le scan de l'app.
- Reste centré sur Tanika, le parfum énergétique, la radiesthésie olfactive et l'usage de l'app. Si la question sort de ce cadre, réoriente poliment.
- Tu n'es pas Nossane elle-même, tu es son assistant. Ne prétends jamais être elle.`;

let historiqueChat = [];

function formaterTexteChat(txt){
  return txt.replace(/(https?:\/\/[^\s]+)/g, '<a href="$1" target="_blank" rel="noopener">$1</a>');
}
function ajouterMessageChat(role, texte){
  const div = document.createElement('div');
  div.className = 'msg ' + (role==='user' ? 'msg-user' : 'msg-bot');
  div.innerHTML = role==='user' ? texte : formaterTexteChat(texte);
  $('#chat-corps').appendChild(div);
  $('#chat-corps').scrollTop = $('#chat-corps').scrollHeight;
  return div;
}
function afficherTape(){
  const div = document.createElement('div');
  div.className = 'msg msg-bot msg-tape-conteneur';
  div.innerHTML = '<div class="msg-tape"><span></span><span></span><span></span></div>';
  div.style.padding = '0';
  $('#chat-corps').appendChild(div);
  $('#chat-corps').scrollTop = $('#chat-corps').scrollHeight;
  return div;
}

async function envoyerMessageChat(texte){
  texte = texte.trim();
  if(!texte) return;
  ajouterMessageChat('user', texte);
  historiqueChat.push({role:'user', content:texte});
  $('#chat-input').value='';
  $('#chat-suggestions').innerHTML='';

  const bulleTape = afficherTape();
  try{
    const reponse = await fetch("https://api.anthropic.com/v1/messages", {
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({
        model:"claude-sonnet-4-6",
        max_tokens:1000,
        system:SYSTEME_CHAT,
        messages:historiqueChat
      })
    });
    const data = await reponse.json();
    const texteReponse = (data.content||[]).filter(b=>b.type==='text').map(b=>b.text).join('\n').trim()
      || "Je n'ai pas pu répondre à l'instant. Tu peux réessayer, ou visiter directement tanikaparfums.fr ✦";
    bulleTape.remove();
    ajouterMessageChat('bot', texteReponse);
    historiqueChat.push({role:'assistant', content:texteReponse});
  }catch(e){
    bulleTape.remove();
    ajouterMessageChat('bot', "Une erreur est survenue. En attendant, tu peux visiter tanikaparfums.fr ou explorer le Scan dans l'app ✦");
  }
}

const SUGGESTIONS_CHAT = [
  "Comment fonctionne le scan de parfum ?",
