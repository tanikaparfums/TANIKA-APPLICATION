async function enregistrerDansBibliotheque(p){
  if(!sessionActuelle) return;
  const uid = sessionActuelle.user.id;
  const entree = {
    user_id:uid, nom:p.nom, marque:p.marque||'', bovis:p.bovis, chakra:p.chakra,
    intention: intentionChoisie ? intentionChoisie.label : ''
  };
  const {error} = await supabaseClient.from('scans').insert(entree);
  if(error){ console.error('Enregistrement scan impossible', error); return; }
  await chargerDonneesPersonnelles();
}
function afficherBibliotheque(){
  const zone=$('#liste-bibliotheque');
  if(!zone) return;
  if(!sessionActuelle){
    zone.innerHTML='<p class="vide">Connecte-toi pour voir et garder ta bibliothèque de scans. ✦</p>';
    $('#btn-comparer').style.display='none';
    return;
  }
  if(!bibliotheque.length){
    zone.innerHTML='<p class="vide">Aucun scan enregistré pour l\'instant.<br>Chaque parfum que tu scannes rejoint ta bibliothèque. ✦</p>';
    $('#btn-comparer').style.display='none';
    return;
  }
  zone.innerHTML = bibliotheque.map((b,i)=>`
    <div class="bib-carte">
      <input type="checkbox" class="bib-check" data-i="${i}">
      <div class="bib-info">
        <div class="bib-nom">${b.nom}</div>
        <div class="bib-meta">${b.marque?b.marque+' · ':''}${formatDateArticle(b.date)}</div>
      </div>
      <div class="bib-bovis">${Number(b.bovis).toLocaleString('fr-FR')}</div>
    </div>`).join('');
  zone.querySelectorAll('.bib-check').forEach(c=>c.addEventListener('change',majBoutonComparer));
  majBoutonComparer();
}
function majBoutonComparer(){
  const coches = [...document.querySelectorAll('.bib-check:checked')];
  $('#btn-comparer').style.display = coches.length===2 ? 'block' : 'none';
  if(coches.length!==2) $('#zone-comparaison').classList.remove('visible');
}
$('#btn-comparer').addEventListener('click',()=>{
  const coches = [...document.querySelectorAll('.bib-check:checked')].map(c=>bibliotheque[Number(c.dataset.i)]);
  if(coches.length!==2) return;
  const maxBovis = Math.max(...coches.map(c=>c.bovis), 14000);
  $('#zone-comparaison').innerHTML = coches.map(c=>{
    const ch=CHAKRAS[c.chakra]||CHAKRAS[3];
    return `<div class="comp-ligne">
      <div class="comp-nom">${c.nom}</div>
      <div class="comp-barre-fond"><div class="comp-barre" style="width:${(c.bovis/maxBovis*100).toFixed(0)}%"></div></div>
      <div class="comp-val">${Number(c.bovis).toLocaleString('fr-FR')}</div>
    </div>
    <div style="text-align:center;font-style:italic;color:var(--brun);font-size:13.5px;margin-top:2px">Chakra ${ch.nom}</div>`;
  }).join('<div style="height:10px"></div>');
  $('#zone-comparaison').classList.add('visible');
  $('#zone-comparaison').scrollIntoView({behavior:'smooth',block:'nearest'});
});

