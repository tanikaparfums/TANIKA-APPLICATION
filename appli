      <div class="cta-doubles">
        <a class="bouton-cta" href="https://tanikaparfums.fr" target="_blank" rel="noopener">✦ Visiter tanikaparfums.fr ✦</a>
        <button class="bouton-or" id="btn-decouvrir-produits">Découvrir mon Scan Olfactif</button>
      </div>

      <p class="pied-signature">✦ <span class="or">Tanika Parfums</span> · une création de Nossane ✦</p>
    </div>

    <!-- ======= SCANNER ======= -->
    <div class="ecran" id="scanner">
      <h2>Le Scan</h2>
      <p class="invocation">En boutique, scanne le code-barres d'un parfum et découvre s'il vibre haut.</p>

      <div class="intention-carte">
        <h4>✦ Ton intention du moment ✦</h4>
        <p class="intention-resume" id="resume-etat">Comment te sens-tu aujourd'hui ?</p>
        <div class="chips" id="chips-etat"></div>
        <p class="intention-resume" id="resume-intention" style="display:none">Quelle énergie souhaites-tu incarner ?</p>
        <div class="chips" id="chips-intention" style="display:none"></div>
        <button class="lien-modifier" id="btn-modifier-intention" style="display:none">Modifier mon intention</button>
      </div>

      <div class="cadre-scan">
        <div id="video-zone">
          <video id="video" playsinline muted></video>
          <div class="viseur"></div>
        </div>
        <div id="scan-accueil">
          <div class="scan-ico">📷</div>
          <p class="scan-txt">Vise le code-barres au dos de la boîte ou du flacon.</p>
        </div>
        <button class="bouton-or" id="btn-camera">Activer la caméra</button>
        <div class="ou">ou</div>
        <label for="scan-nom" style="text-align:left">Rechercher par nom</label>
        <input type="text" id="scan-nom" placeholder="Ex. : Paradoxe, Libre, Baccarat…">
        <button class="bouton-or bouton-ligne" id="btn-chercher">Chercher dans le répertoire</button>
      </div>

      <div class="non-trouve" id="non-trouve"></div>

      <div class="verdict" id="verdict"></div>

      <p class="pied-signature">✦ <span class="or">Tanika Parfums</span> · une création de Nossane ✦</p>
    </div>

    <!-- ======= CLASSEUR ======= -->
    <div class="ecran" id="classeur">
      <h2>Le Classeur</h2>
      <p class="invocation">Le répertoire des parfums qui vibrent haut, enrichi jour après jour par Nossane.</p>

      <div class="recherche">
        <input type="text" id="filtre" placeholder="🔍 Rechercher un parfum, une marque, une note…">
      </div>
      <div class="compteur" id="compteur"></div>
      <div id="liste-classeur"></div>

      <details class="creatrice">
        <summary>✦ Espace créatrice <span class="badge-verrouille" id="badge-classeur">🔒</span> ✦</summary>

        <div class="verrou" id="verrou-classeur">
          <div class="ico-v">🔒</div>
          <p>Cet espace est réservé à Nossane.<br>Connecte-toi avec ton compte administrateur dans l'onglet « Mon Espace » pour ajouter un parfum.</p>
        </div>

        <div class="zone-creatrice" id="zone-classeur">
        <p class="note-part">Tes ajouts rejoignent le répertoire visible par tes clientes.</p>
