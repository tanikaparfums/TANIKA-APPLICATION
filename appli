<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#FBF7EE">
<title>L'Olfactothèque Tanika</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root{
    --ivoire:#FBF7EE; --ivoire-fonce:#F3EBD9;
    --or:#C9A227; --or-clair:#E3C766; --or-pale:#EFE2B8;
    --encre:#2E2A1F; --royal:#1E2C63; --brun:#6B5E3F;
    --vert:#3E8E5A; --terre:#B5483A;
    --c1:#B5483A; --c2:#D97A2B; --c3:#D9B428; --c4:#3E8E5A; --c5:#33689E; --c6:#5B3D8C; --c7:#8C79C2;
    --nav-h:72px; --safe-bas:env(safe-area-inset-bottom,0px);
  }
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{height:100%}
  body{
    background:var(--ivoire);color:var(--encre);
    font-family:'Cormorant Garamond',serif;font-size:18px;
    overflow:hidden;position:fixed;inset:0;
    user-select:none;-webkit-user-select:none;
  }
  input,textarea,select{user-select:text;-webkit-user-select:text}

  /* SPLASH */
  #splash{
    position:fixed;inset:0;z-index:100;
    background:radial-gradient(circle at 50% 38%,#27387A,var(--royal) 75%);
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    transition:opacity .8s ease, visibility .8s;
  }
  #splash.cache{opacity:0;visibility:hidden;pointer-events:none}
  #splash .logo{font-family:'Cinzel Decorative',serif;font-size:38px;letter-spacing:.22em;color:var(--or-clair);animation:lueur 2.4s ease infinite alternate}
  #splash .ligne{font-style:italic;color:#EFE2B8;margin-top:8px;font-size:17px;letter-spacing:.05em;text-align:center;padding:0 30px}
  #splash .symbole{color:var(--or-clair);margin-top:24px;font-size:22px;animation:pulse 1.6s ease infinite}
  @keyframes lueur{from{text-shadow:0 0 12px #E3C76633}to{text-shadow:0 0 28px #E3C766AA}}
  @keyframes pulse{0%,100%{opacity:.4}50%{opacity:1}}

  .mandala-bg{position:fixed;top:42%;left:50%;width:160vmax;height:160vmax;transform:translate(-50%,-50%);opacity:.04;pointer-events:none;z-index:0;animation:rotation 240s linear infinite}
  @keyframes rotation{to{transform:translate(-50%,-50%) rotate(360deg)}}
  @media (prefers-reduced-motion:reduce){.mandala-bg{animation:none}*{transition:none!important;animation-duration:.01s!important}}

  #app{position:fixed;inset:0;display:flex;flex-direction:column;z-index:1}
  .barre-haut{text-align:center;padding:calc(14px + env(safe-area-inset-top,0px)) 16px 10px;background:linear-gradient(180deg,var(--ivoire) 70%,transparent);z-index:5}
  .barre-haut .titre{font-family:'Cinzel Decorative',serif;font-size:16px;letter-spacing:.2em;color:var(--royal);font-weight:700}
  .barre-haut .souligne{width:52px;height:2px;margin:7px auto 0;background:linear-gradient(90deg,transparent,var(--or),transparent)}

  .ecrans{flex:1;position:relative;overflow:hidden}
  .ecran{position:absolute;inset:0;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:6px 18px calc(var(--nav-h) + var(--safe-bas) + 24px);opacity:0;transform:translateX(22px);pointer-events:none;transition:opacity .35s ease,transform .35s ease}
  .ecran.actif{opacity:1;transform:none;pointer-events:auto}

  .barre-nav{position:fixed;left:0;right:0;bottom:0;z-index:10;height:calc(var(--nav-h) + var(--safe-bas));padding-bottom:var(--safe-bas);background:rgba(251,247,238,.92);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-top:1px solid var(--or-pale);display:flex}
  .onglet{flex:1;border:none;background:none;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;color:var(--brun);transition:color .25s;font-family:'Cormorant Garamond',serif}
  .onglet .ico{font-size:22px;transition:transform .25s}
  .onglet .lib{font-family:'Cinzel Decorative',serif;font-size:9px;letter-spacing:.1em;text-transform:uppercase}
  .onglet.actif{color:var(--royal)}
  .onglet.actif .ico{transform:translateY(-3px) scale(1.12)}
  .onglet.actif::after{content:"";width:5px;height:5px;border-radius:50%;background:var(--or);margin-top:1px}

  h2{font-family:'Cinzel Decorative',serif;font-size:20px;letter-spacing:.1em;text-align:center;color:var(--royal);font-weight:400;margin-top:14px}
  .invocation{text-align:center;font-style:italic;color:var(--brun);margin:8px 0 18px;font-size:16.5px;line-height:1.4}
  label{display:block;font-family:'Cinzel Decorative',serif;font-size:10px;letter-spacing:.16em;color:var(--brun);margin:14px 0 6px;text-transform:uppercase}
  input[type=text],input[type=number],textarea,select{width:100%;background:#FFFDF7;border:1px solid var(--or-pale);border-radius:10px;padding:12px 13px;font-family:'Cormorant Garamond',serif;font-size:17px;color:var(--encre)}
  input:focus,textarea:focus,select:focus{outline:none;border-color:var(--or);box-shadow:0 0 0 2px var(--or-pale)}
  textarea{resize:none;min-height:70px}
  .bouton-or{display:block;width:100%;margin:18px auto 0;font-family:'Cinzel Decorative',serif;font-size:12.5px;letter-spacing:.14em;color:var(--ivoire);background:linear-gradient(180deg,var(--or-clair),var(--or));border:none;padding:15px;border-radius:14px;cursor:pointer;box-shadow:0 3px 12px #C9A22744;transition:transform .2s}
  .bouton-or:active{transform:scale(.97)}
  .bouton-ligne{background:none;border:1px solid var(--or-pale);color:var(--brun);box-shadow:none}

  /* ACCUEIL */
  .accueil-hero{text-align:center;padding:18px 4px 6px}
  .accueil-logo{font-family:'Cinzel Decorative',serif;font-size:36px;letter-spacing:.2em;color:var(--royal);font-weight:700}
  .accueil-baseline{font-style:italic;color:var(--brun);margin-top:6px;font-size:17px;line-height:1.4}
  .accueil-carte{border:1px solid var(--or-pale);border-radius:16px;background:linear-gradient(160deg,#FFFDF7,var(--ivoire-fonce));padding:20px 18px;margin-top:22px}
  .accueil-carte h3{font-family:'Cinzel Decorative',serif;font-size:13px;letter-spacing:.12em;color:var(--royal);text-transform:uppercase;margin-bottom:8px;text-align:center}
  .accueil-carte p{font-size:16.5px;line-height:1.55}
  .accueil-carte p+p{margin-top:10px}
  .fonctions{display:flex;flex-direction:column;gap:10px;margin-top:22px}
  .fonction{display:flex;align-items:center;gap:13px;border:1px solid var(--or-pale);border-radius:12px;background:#FFFDF7;padding:12px 14px}
  .fonction .fi{font-size:22px;flex-shrink:0}
  .fonction .ft b{font-family:'Cinzel Decorative',serif;font-size:12px;letter-spacing:.05em;color:var(--royal);display:block}
  .fonction .ft span{font-style:italic;color:var(--brun);font-size:14.5px}
  .accueil-signature-bloc{text-align:center;margin-top:26px;padding:18px;border-top:1px solid var(--or-pale);border-bottom:1px solid var(--or-pale)}
  .accueil-signature-bloc .pretresse{font-family:'Cinzel Decorative',serif;font-size:12px;letter-spacing:.1em;color:var(--or);text-transform:uppercase}
  .accueil-signature-bloc p{font-style:italic;color:var(--brun);margin-top:8px;font-size:15.5px;line-height:1.5}
  .cta-doubles{display:flex;flex-direction:column;gap:10px;margin-top:22px}

  /* SCANNER D'INTENTION */
  .intention-carte{border:1px solid var(--or-pale);border-radius:16px;background:linear-gradient(160deg,#FFFDF7,var(--ivoire-fonce));padding:18px;margin-bottom:16px}
  .intention-carte h4{font-family:'Cinzel Decorative',serif;font-size:11.5px;letter-spacing:.12em;color:var(--royal);text-transform:uppercase;text-align:center}
  .chips{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:12px}
  .chip{border:1px solid var(--or-pale);background:#FFFDF7;border-radius:20px;padding:9px 15px;font-size:15px;color:var(--encre);cursor:pointer;transition:all .2s}
  .chip.choisi{background:var(--royal);border-color:var(--royal);color:var(--or-clair)}
  .chip:active{transform:scale(.96)}
  .intention-resume{text-align:center;font-style:italic;color:var(--brun);font-size:14.5px;margin-top:12px;min-height:20px}
  .lien-modifier{display:block;text-align:center;font-style:italic;color:var(--brun);font-size:13.5px;text-decoration:underline;margin-top:6px;background:none;border:none;cursor:pointer}

  /* SCANNER */
  .cadre-scan{border:1px solid var(--or-pale);border-radius:18px;background:linear-gradient(160deg,#FFFDF7,var(--ivoire-fonce));padding:20px;text-align:center;margin-top:10px}
  #video-zone{position:relative;width:100%;aspect-ratio:3/4;max-height:300px;background:#151b3a;border-radius:14px;overflow:hidden;display:none;margin-bottom:14px}
  #video-zone.actif{display:block}
  #video{width:100%;height:100%;object-fit:cover}
  .viseur{position:absolute;inset:20% 12%;border:2px solid var(--or-clair);border-radius:10px;box-shadow:0 0 0 2000px rgba(21,27,58,.35)}
  .viseur::after{content:"";position:absolute;left:0;right:0;top:50%;height:2px;background:var(--or-clair);box-shadow:0 0 8px var(--or-clair);animation:balaye 2s ease-in-out infinite}
  @keyframes balaye{0%,100%{top:12%}50%{top:88%}}
  .scan-ico{font-size:42px;color:var(--or)}
  .scan-txt{font-style:italic;color:var(--brun);margin:10px 0 4px;font-size:16px;line-height:1.4}
  .ou{display:flex;align-items:center;gap:10px;margin:18px 0 4px;color:var(--brun);font-style:italic;font-size:14px}
  .ou::before,.ou::after{content:"";flex:1;height:1px;background:var(--or-pale)}

  /* CARTE VERDICT */
  .verdict{display:none;margin-top:16px}
  .verdict.visible{display:block;animation:apparition .5s ease}
  @keyframes apparition{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
  .v-carte{border-radius:18px;padding:24px 20px;text-align:center;box-shadow:0 8px 24px #2E2A1F1A;border:1px solid var(--or)}
  .v-tres-haute{background:radial-gradient(circle at 50% 0%,#2b3d84,var(--royal));color:#F7EFD8;border-color:var(--or-clair)}
  .v-haute{background:linear-gradient(165deg,#FFFDF7,var(--or-pale));color:var(--encre)}
  .v-positive{background:linear-gradient(165deg,#FFFDF7,#E7F0E7);color:var(--encre)}
  .v-basse{background:linear-gradient(165deg,#FFFDF7,#F2E2DF);color:var(--encre)}
  .v-badge{font-family:'Cinzel Decorative',serif;font-size:13px;letter-spacing:.16em;text-transform:uppercase;font-weight:700}
  .v-tres-haute .v-badge{color:var(--or-clair)}
  .v-haute .v-badge{color:var(--or)}
  .v-positive .v-badge{color:var(--vert)}
  .v-basse .v-badge{color:var(--terre)}
  .v-nom{font-family:'Cinzel Decorative',serif;font-size:22px;margin-top:12px;line-height:1.25}
  .v-marque{font-style:italic;opacity:.8;margin-top:2px;font-size:16px}
  .v-bovis{font-family:'Cinzel Decorative',serif;font-size:40px;margin-top:16px;letter-spacing:.02em}
  .v-unite{font-size:12px;letter-spacing:.16em;text-transform:uppercase;opacity:.75;font-family:'Cinzel Decorative',serif}
  .v-pastille{display:inline-flex;align-items:center;gap:7px;margin-top:12px;font-size:15px}
  .v-pastille i{width:10px;height:10px;border-radius:50%;display:inline-block;border:1px solid #0003}
  .v-notes{font-style:italic;margin-top:6px;font-size:16px;opacity:.85}
  .v-pourquoi{font-size:16.5px;line-height:1.5;margin-top:16px;text-align:left}
  .v-compat{margin-top:16px;padding:12px 14px;border-radius:12px;text-align:left;font-size:15.5px;line-height:1.4}
  .v-compat.oui{background:rgba(62,142,90,.15)}
  .v-compat.non{background:rgba(181,72,58,.13)}
  .v-tres-haute .v-compat.oui{background:rgba(227,199,102,.18)}
  .v-tres-haute .v-compat.non{background:rgba(255,255,255,.08)}
  .v-compat b{font-family:'Cinzel Decorative',serif;font-size:11px;letter-spacing:.08em;display:block;margin-bottom:3px;text-transform:uppercase}
  .v-moments{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;margin-top:14px}
  .v-tag{font-size:12.5px;border:1px solid rgba(107,94,63,.3);border-radius:20px;padding:5px 11px}
  .v-tres-haute .v-tag{border-color:rgba(227,199,102,.4);color:var(--or-clair)}
  .v-oracle{margin-top:18px;padding:16px 14px;border-radius:12px;background:rgba(0,0,0,.04);text-align:left;position:relative}
  .v-tres-haute .v-oracle{background:rgba(255,255,255,.06)}
  .v-oracle .et-oracle{font-family:'Cinzel Decorative',serif;font-size:10px;letter-spacing:.14em;text-transform:uppercase;opacity:.7}
  .v-oracle .txt-oracle{font-style:italic;font-size:16.5px;line-height:1.5;margin-top:6px}
  .cta-bloc{margin-top:18px;padding-top:18px;border-top:1px solid rgba(201,162,39,.35)}
  .cta-txt{font-size:15px;font-style:italic;line-height:1.4;opacity:.9}
  .bouton-cta{display:block;width:100%;margin:12px auto 0;text-align:center;text-decoration:none;font-family:'Cinzel Decorative',serif;font-size:11.5px;letter-spacing:.12em;color:#F7EFD8;background:linear-gradient(180deg,#27387A,var(--royal));padding:15px 12px;border-radius:14px;box-shadow:0 3px 12px #1E2C6344;transition:transform .2s}
  .v-tres-haute .bouton-cta{background:linear-gradient(180deg,var(--or-clair),var(--or));color:var(--royal)}
  .bouton-cta:active{transform:scale(.97)}
  .non-trouve{text-align:center;font-style:italic;color:var(--brun);background:#FFFDF7;border:1px dashed var(--or-pale);border-radius:12px;padding:18px;margin-top:14px;line-height:1.5;font-size:16px;display:none}
  .non-trouve.visible{display:block}

  /* CLASSEUR */
  .recherche{position:relative;margin-top:6px}
  .compteur{text-align:center;font-style:italic;color:var(--brun);font-size:14px;margin:10px 0 4px}
  .parfum{border:1px solid var(--or-pale);border-left:4px solid var(--or);border-radius:12px;background:#FFFDF7;padding:14px 15px;margin-bottom:11px;cursor:pointer;transition:transform .15s}
  .parfum:active{transform:scale(.99)}
  .p-tete{display:flex;justify-content:space-between;align-items:flex-start;gap:10px}
  .p-nom{font-family:'Cinzel Decorative',serif;font-size:16px;color:var(--royal);line-height:1.25}
  .p-marque{font-style:italic;color:var(--brun);font-size:15px}
  .p-bovis{text-align:right;flex-shrink:0}
  .p-bovis b{font-family:'Cinzel Decorative',serif;font-size:19px;color:var(--encre);display:block}
  .p-mini-badge{font-family:'Cinzel Decorative',serif;font-size:8.5px;letter-spacing:.1em;text-transform:uppercase;padding:2px 7px;border-radius:20px;display:inline-block;margin-top:2px}
  .mb-tres{background:var(--royal);color:var(--or-clair)}
  .mb-haute{background:var(--or-pale);color:var(--brun)}
  .mb-pos{background:#E1EEE1;color:var(--vert)}
  .mb-basse{background:#F2E2DF;color:var(--terre)}
  .p-detail{max-height:0;overflow:hidden;transition:max-height .35s ease}
  .parfum.ouvert .p-detail{max-height:300px;margin-top:10px}
  .p-detail .l{font-size:15.5px;margin-top:5px;line-height:1.4}
  .p-detail .l b{color:var(--brun)}
  .vide{text-align:center;font-style:italic;color:var(--brun);padding:26px 12px;line-height:1.5}

  /* Espace créatrice */
  .creatrice{border:1px solid var(--or-pale);border-radius:14px;background:linear-gradient(160deg,#FFFDF7,var(--ivoire-fonce));padding:16px;margin-top:20px}
  .creatrice summary{font-family:'Cinzel Decorative',serif;font-size:12px;letter-spacing:.12em;color:var(--royal);cursor:pointer;text-transform:uppercase;list-style:none;text-align:center}
  .creatrice summary::-webkit-details-marker{display:none}
  .creatrice[open] summary{margin-bottom:6px}
  .note-part{font-style:italic;color:var(--brun);font-size:14px;text-align:center;margin:8px 0 4px;line-height:1.4}

  /* VERROU CRÉATRICE */
  .verrou{text-align:center;padding:8px 2px}
  .verrou .ico-v{font-size:28px;color:var(--or)}
  .verrou p{font-style:italic;color:var(--brun);font-size:14.5px;margin:8px 0 12px;line-height:1.4}
  .verrou input{text-align:center;letter-spacing:.12em}
  .erreur-pin{color:var(--terre);font-size:13.5px;font-style:italic;margin-top:8px;display:none}
  .erreur-pin.visible{display:block}
  .zone-creatrice{display:none}
  .zone-creatrice.visible{display:block}
  .badge-verrouille{display:inline-block;font-size:11px;color:var(--or);margin-left:6px}

  /* ARTICLES */
  .article{border:1px solid var(--or-pale);border-left:4px solid var(--or);border-radius:12px;background:#FFFDF7;padding:15px 16px;margin-bottom:12px;cursor:pointer}
  .art-tete{display:flex;justify-content:space-between;align-items:flex-start;gap:8px}
  .art-cat{font-family:'Cinzel Decorative',serif;font-size:9px;letter-spacing:.12em;color:var(--or);text-transform:uppercase}
  .art-titre{font-family:'Cinzel Decorative',serif;font-size:17px;color:var(--royal);margin-top:4px;line-height:1.3}
  .art-meta{font-style:italic;color:var(--brun);font-size:14px;margin-top:3px}
  .art-corps{max-height:0;overflow:hidden;transition:max-height .4s ease}
  .article.ouvert .art-corps{max-height:1200px;margin-top:10px}
  .art-texte{font-size:16.5px;line-height:1.55;white-space:pre-wrap}
  .suppr-art{background:none;border:none;color:var(--brun);opacity:.5;font-size:14px;cursor:pointer;flex-shrink:0}

  /* SIGNATURE TANIKA */
  .signature{font-style:italic;color:var(--brun);font-size:11.5px;letter-spacing:.03em;margin-top:2px}
  .pied-signature{text-align:center;font-style:italic;color:var(--brun);font-size:14px;margin:28px 0 6px;letter-spacing:.03em}
  .pied-signature .or{color:var(--or)}

  /* JOURNAL */
  .curseur-bloc{display:flex;align-items:center;gap:14px;margin-top:4px}
  input[type=range]{flex:1;accent-color:var(--or)}
  .val-e{font-family:'Cinzel Decorative',serif;color:var(--royal);min-width:30px;text-align:center;font-size:18px}
  .entree{border:1px solid var(--or-pale);border-left:3px solid var(--or);border-radius:12px;background:#FFFDF7;padding:14px 15px;margin-bottom:12px;position:relative}
  .entree .date{font-family:'Cinzel Decorative',serif;font-size:9.5px;letter-spacing:.14em;color:var(--or);text-transform:uppercase}
  .entree .parf{font-size:18px;color:var(--royal);font-weight:600;margin-top:3px}
  .entree .l{font-size:15.5px;margin-top:4px}
  .entree .l b{color:var(--brun)}
  .jauge{height:5px;background:var(--or-pale);border-radius:3px;margin-top:8px;overflow:hidden}
  .jauge i{display:block;height:100%;background:linear-gradient(90deg,var(--or-clair),var(--or))}
  .suppr{position:absolute;top:9px;right:11px;background:none;border:none;color:var(--brun);cursor:pointer;font-size:14px;opacity:.5}

  /* PROFIL & BIBLIOTHÈQUE */
  .profil-bloc{border:1px solid var(--or-pale);border-radius:14px;background:linear-gradient(160deg,#FFFDF7,var(--ivoire-fonce));padding:16px;text-align:center;margin-bottom:22px}
  .profil-bloc.rempli{padding:12px 16px}
  .profil-salut{font-family:'Cinzel Decorative',serif;font-size:15px;color:var(--royal);letter-spacing:.03em}
  .profil-note{font-style:italic;color:var(--brun);font-size:14px;margin-top:4px}
  .separateur-titre{font-family:'Cinzel Decorative',serif;font-size:13px;letter-spacing:.1em;color:var(--royal);text-transform:uppercase;text-align:center;margin:28px 0 4px}
  .bib-carte{border:1px solid var(--or-pale);border-radius:12px;background:#FFFDF7;padding:12px 14px;margin-bottom:10px;display:flex;align-items:center;gap:12px}
  .bib-check{width:20px;height:20px;accent-color:var(--or);flex-shrink:0}
  .bib-info{flex:1}
  .bib-nom{font-family:'Cinzel Decorative',serif;font-size:15.5px;color:var(--royal)}
  .bib-meta{font-style:italic;color:var(--brun);font-size:13.5px;margin-top:2px}
  .bib-bovis{font-family:'Cinzel Decorative',serif;font-size:16px;color:var(--encre);flex-shrink:0}
  .comparaison{border:1px solid var(--or);border-radius:16px;background:linear-gradient(160deg,#FFFDF7,var(--or-pale));padding:18px;margin:16px 0;display:none}
  .comparaison.visible{display:block;animation:apparition .5s ease}
  .comp-ligne{display:flex;justify-content:space-between;align-items:center;gap:10px;margin-top:12px}
  .comp-nom{font-family:'Cinzel Decorative',serif;font-size:14px;color:var(--royal);flex:1}
  .comp-barre-fond{flex:2;height:8px;background:#fff;border-radius:4px;overflow:hidden}
  .comp-barre{height:100%;background:linear-gradient(90deg,var(--or-clair),var(--or))}
  .comp-val{font-family:'Cinzel Decorative',serif;font-size:14px;width:52px;text-align:right}

  /* MANTRAS */
  .mantra-jour{border:1px solid var(--or);border-radius:18px;box-shadow:inset 0 0 0 5px var(--ivoire),inset 0 0 0 6px var(--or-clair);background:radial-gradient(circle at 50% 0%,#2b3d84,var(--royal));color:#F7EFD8;padding:26px 22px;text-align:center;margin-top:12px}
  .mantra-jour .et{font-family:'Cinzel Decorative',serif;font-size:10px;letter-spacing:.2em;color:var(--or-clair);text-transform:uppercase}
  .mantra-jour .txt{font-style:italic;font-size:20px;line-height:1.45;margin-top:12px}
  .mantra-jour .theme{font-family:'Cinzel Decorative',serif;font-size:11px;letter-spacing:.14em;color:var(--or-clair);margin-top:14px;text-transform:uppercase}
  .rituel{border:1px solid var(--or-pale);border-radius:14px;background:#FFFDF7;padding:16px;margin-top:16px}
  .rituel h3{font-family:'Cinzel Decorative',serif;font-size:12px;letter-spacing:.12em;color:var(--royal);text-transform:uppercase;text-align:center;margin-bottom:10px}
  .rituel ol{list-style:none;counter-reset:r}
  .rituel li{counter-increment:r;position:relative;padding:6px 0 6px 34px;font-size:16px;line-height:1.4}
  .rituel li::before{content:counter(r);position:absolute;left:0;top:6px;width:22px;height:22px;border-radius:50%;background:var(--or-pale);color:var(--brun);font-family:'Cinzel Decorative',serif;font-size:12px;display:flex;align-items:center;justify-content:center}
  .m-liste{margin-top:18px}
  .m-carte{border:1px solid var(--or-pale);border-radius:12px;background:#FFFDF7;padding:14px 15px;margin-bottom:11px}
  .m-carte .theme{font-family:'Cinzel Decorative',serif;font-size:10px;letter-spacing:.12em;color:var(--or);text-transform:uppercase}
  .m-carte .txt{font-style:italic;font-size:17px;margin-top:5px;line-height:1.4}

  /* CHATBOT */
  .bulle-chat{
    position:fixed;right:16px;z-index:20;
    bottom:calc(var(--nav-h) + var(--safe-bas) + 16px);
    width:54px;height:54px;border-radius:50%;
    background:radial-gradient(circle at 35% 30%,#2b3d84,var(--royal));
    border:2px solid var(--or-clair);color:var(--or-clair);
    display:flex;align-items:center;justify-content:center;font-size:24px;
    box-shadow:0 4px 16px #1E2C6355;cursor:pointer;
  }
  .bulle-chat:active{transform:scale(.93)}
  #modal-chat{
    position:fixed;inset:0;z-index:50;background:rgba(46,42,31,.45);
    display:none;align-items:flex-end;justify-content:center;
  }
  #modal-chat.visible{display:flex}
  .chat-panneau{
    width:100%;max-width:480px;height:min(78vh,640px);
    background:var(--ivoire);border-radius:22px 22px 0 0;
    display:flex;flex-direction:column;overflow:hidden;
    box-shadow:0 -8px 30px #2E2A1F33;
  }
  .chat-tete{
    background:linear-gradient(135deg,#27387A,var(--royal));color:#F7EFD8;
    padding:16px 18px;display:flex;align-items:center;justify-content:space-between;
  }
  .chat-tete .ct-nom{font-family:'Cinzel Decorative',serif;font-size:14px;letter-spacing:.08em}
  .chat-tete .ct-sous{font-style:italic;font-size:12.5px;opacity:.85;margin-top:2px}
  .chat-fermer{background:none;border:none;color:#F7EFD8;font-size:20px;cursor:pointer;padding:4px 8px}
  .chat-corps{flex:1;overflow-y:auto;padding:16px;-webkit-overflow-scrolling:touch}
  .msg{max-width:82%;margin-bottom:12px;padding:11px 14px;border-radius:14px;font-size:15.5px;line-height:1.4}
  .msg-bot{background:#FFFDF7;border:1px solid var(--or-pale);border-bottom-left-radius:4px}
  .msg-user{background:var(--royal);color:#F7EFD8;margin-left:auto;border-bottom-right-radius:4px}
  .msg-bot a{color:var(--royal);font-weight:600}
  .msg-tape{display:flex;gap:4px;padding:11px 14px}
  .msg-tape span{width:6px;height:6px;border-radius:50%;background:var(--or);animation:tape 1.2s infinite}
  .msg-tape span:nth-child(2){animation-delay:.2s}
  .msg-tape span:nth-child(3){animation-delay:.4s}
  @keyframes tape{0%,60%,100%{opacity:.3}30%{opacity:1}}
  .chat-suggestions{display:flex;gap:8px;overflow-x:auto;padding:0 16px 12px;flex-shrink:0}
  .chat-chip{flex-shrink:0;font-size:13.5px;border:1px solid var(--or-pale);background:#FFFDF7;border-radius:16px;padding:8px 13px;cursor:pointer;white-space:nowrap}
  .chat-saisie{display:flex;gap:8px;padding:12px 14px;border-top:1px solid var(--or-pale);flex-shrink:0}
  .chat-saisie input{flex:1;border-radius:20px;padding:11px 16px}
  .chat-envoyer{width:42px;height:42px;border-radius:50%;background:var(--or);border:none;color:var(--ivoire);font-size:17px;cursor:pointer;flex-shrink:0}

  /* AUTHENTIFICATION */
  .auth-carte{border:1px solid var(--or-pale);border-radius:16px;background:linear-gradient(160deg,#FFFDF7,var(--ivoire-fonce));padding:20px 18px;text-align:center}
  .auth-onglets{display:flex;gap:6px;margin-bottom:16px}
  .auth-onglet{flex:1;border:1px solid var(--or-pale);background:#FFFDF7;border-radius:10px;padding:10px;font-family:'Cinzel Decorative',serif;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--brun);cursor:pointer}
  .auth-onglet.actif{background:var(--royal);color:var(--or-clair);border-color:var(--royal)}
  .auth-erreur{color:var(--terre);font-size:14px;font-style:italic;margin-top:10px;display:none;text-align:left}
  .auth-erreur.visible{display:block}
  .auth-note{font-style:italic;color:var(--brun);font-size:13.5px;margin-top:12px;line-height:1.4}
  .profil-connecte{display:flex;align-items:center;justify-content:space-between;gap:10px}
  .btn-deconnexion{background:none;border:1px solid var(--or-pale);color:var(--brun);font-family:'Cormorant Garamond',serif;font-style:italic;font-size:13.5px;padding:6px 12px;border-radius:20px;cursor:pointer;flex-shrink:0}
  .admin-etiquette{display:inline-block;font-family:'Cinzel Decorative',serif;font-size:9px;letter-spacing:.1em;color:var(--or);background:var(--royal);padding:3px 9px;border-radius:20px;margin-left:6px;vertical-align:middle}
  .verrou-connexion{text-align:center;padding:8px 2px}
  .verrou-connexion .ico-v{font-size:28px;color:var(--or)}
  .verrou-connexion p{font-style:italic;color:var(--brun);font-size:14.5px;margin:8px 0 12px;line-height:1.4}
</style>
</head>
<body>

<div id="splash">
