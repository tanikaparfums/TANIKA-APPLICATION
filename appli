  $('#compteur').textContent = `${liste.length} parfum${liste.length>1?'s':''} référencé${liste.length>1?'s':''}`;
  const zone=$('#liste-classeur');
  if(!liste.length){ zone.innerHTML='<p class="vide">Aucun parfum ne correspond. ✦</p>'; return; }
  zone.innerHTML = liste.map((p,i)=>{
    const v=vibe(p.bovis), ch=CHAKRAS[p.chakra]||CHAKRAS[3];
    return `<div class="parfum" data-i="${i}">
      <div class="p-tete">
        <div><div class="p-nom">${p.nom}</div><div class="p-marque">${p.marque||''}</div></div>
        <div class="p-bovis"><b>${Number(p.bovis).toLocaleString('fr-FR')}</b>
          <span class="p-mini-badge ${badgeClasse(v)}">${v.label}</span></div>
      </div>
      <div class="p-detail">
        ${p.famille?`<div class="l"><b>Famille :</b> ${p.famille}</div>`:''}
        <div class="l"><b>Résonance :</b> chakra ${ch.nom}</div>
        ${p.pourquoi?`<div class="l">${p.pourquoi}</div>`:''}
      </div>
    </div>`;
  }).join('');
  zone.querySelectorAll('.parfum').forEach(el=>el.addEventListener('click',()=>el.classList.toggle('ouvert')));
}
