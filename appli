    <circle cx="200" cy="200" r="150"/><circle cx="200" cy="200" r="190"/>
    <g id="petales"></g>
  </g>
</svg>

<div id="app">
  <div class="barre-haut">
    <div class="titre" id="titre-haut">L'OLFACTOTHÈQUE</div>
    <div class="signature">Tanika Parfums · par Nossane</div>
    <div class="souligne"></div>
  </div>

  <div class="ecrans">

    <!-- ======= ACCUEIL ======= -->
    <div class="ecran actif" id="accueil">
      <div class="accueil-hero">
        <div class="accueil-logo">TANIKA</div>
        <p class="accueil-baseline">L'Olfactothèque, le répertoire vivant des parfums qui vibrent haut</p>
      </div>

      <div class="accueil-carte">
        <h3>Pourquoi cette application</h3>
        <p>Chaque parfum porte une fréquence. Certains élèvent, d'autres alourdissent, et la plupart des gens choisissent leur fragrance sans jamais se poser la question.</p>
        <p>J'ai créé l'Olfactothèque pour rendre cette lecture accessible à toutes : scanner un parfum en boutique, savoir s'il vibre haut, et comprendre pourquoi, avant même de l'acheter.</p>
      </div>

      <div class="fonctions">
        <div class="fonction"><span class="fi">📷</span><span class="ft"><b>Scanne en boutique</b><span>Code-barres ou nom, verdict immédiat</span></span></div>
        <div class="fonction"><span class="fi">🔮</span><span class="ft"><b>Compatibilité d'intention</b><span>Amour, confiance, abondance…</span></span></div>
        <div class="fonction"><span class="fi">📖</span><span class="ft"><b>Ta bibliothèque</b><span>Retrouve et compare tes scans</span></span></div>
        <div class="fonction"><span class="fi">📿</span><span class="ft"><b>Mantras & rituels</b><span>Active ton parfum par la parole</span></span></div>
        <div class="fonction"><span class="fi">📰</span><span class="ft"><b>Articles</b><span>Guidance olfactive, notes & vertus</span></span></div>
      </div>

