async function demarrerCamera(){
  if(!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia){
    montrerNonTrouve("caméra indisponible ici"); 
    $('#non-trouve').innerHTML="La caméra n'est pas accessible dans cet aperçu. Une fois l'app installée sur ton téléphone, le scan du code-barres fonctionnera. En attendant, utilise la recherche par nom. ✦";
    $('#non-trouve').classList.add('visible');
    return;
  }
  try{
    flux = await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment'}});
    const video=$('#video'); video.srcObject=flux; await video.play();
    $('#video-zone').classList.add('actif'); $('#scan-accueil').style.display='none';
    $('#btn-camera').textContent='Arrêter la caméra';
    if('BarcodeDetector' in window){
      detecteur = new BarcodeDetector({formats:['ean_13','ean_8','upc_a','upc_e']});
      scannerBoucle();
    }
  }catch(e){
    montrerNonTrouve("accès caméra refusé");
    $('#non-trouve').innerHTML="L'accès à la caméra a été refusé. Autorise-le dans les réglages, ou utilise la recherche par nom. ✦";
    $('#non-trouve').classList.add('visible');
  }
}
async function scannerBoucle(){
  if(!detecteur || !flux) return;
  try{
    const codes = await detecteur.detect($('#video'));
    if(codes.length){
      const code = codes[0].rawValue;
      if(chercherParCode(code)){ arreterCamera(); return; }
      else{ arreterCamera(); montrerNonTrouve("code "+code); return; }
    }
  }catch(e){}
  boucle = requestAnimationFrame(scannerBoucle);
}
function arreterCamera(){
  if(boucle) cancelAnimationFrame(boucle);
  if(flux){ flux.getTracks().forEach(t=>t.stop()); flux=null; }
  $('#video-zone').classList.remove('actif'); 
  const sa=$('#scan-accueil'); if(sa) sa.style.display='block';
  const bc=$('#btn-camera'); if(bc) bc.textContent='Activer la caméra';
}
$('#btn-camera').addEventListener('click',()=>{ flux ? arreterCamera() : demarrerCamera(); });

