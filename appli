/* ============ SCANNER ============ */
let flux=null, detecteur=null, boucle=null;

function afficherVerdict(p){
  const v=vibe(p.bovis), ch=CHAKRAS[p.chakra]||CHAKRAS[3];
  $('#non-trouve').classList.remove('visible');
  const haut = p.bovis>=10000;
  const pIntentions = p.intentions||[], pMoments = p.moments||[];

  let blocCompat='';
  if(intentionChoisie){
    const aligne = pIntentions.includes(intentionChoisie.cle) ||
      (p.chakra!==undefined && intentionChoisie.chakras.includes(p.chakra));
    blocCompat = aligne
      ? `<div class="v-compat oui"><b>✦ Aligné avec ton intention</b>« ${intentionChoisie.label} », cette fragrance soutient directement cette énergie aujourd'hui.</div>`
      : `<div class="v-compat non"><b>Pas la fragrance du jour</b>Pour « ${intentionChoisie.label} », ce parfum n'est pas le plus soutenant. Il reste une belle énergie, pour un autre moment.</div>`;
  }

  const blocMoments = pMoments.length
    ? `<div class="v-moments">${pMoments.map(m=>{const mo=MOMENTS.find(x=>x.cle===m); return mo?`<span class="v-tag">${mo.ico} ${mo.label}</span>`:'';}).join('')}</div>`
    : '';

  const blocOracle = p.oracle
    ? `<div class="v-oracle"><div class="et-oracle">Carte Oracle</div><div class="txt-oracle">${p.oracle}</div></div>`
    : '';

  $('#verdict').innerHTML=`
    <div class="v-carte v-${v.cls}">
      <div class="v-badge">${v.badge}</div>
      <div class="v-nom">${p.nom}</div>
      <div class="v-marque">${p.marque||''}</div>
      <div class="v-bovis">${Number(p.bovis).toLocaleString('fr-FR')}<span class="v-unite"> U.B.</span></div>
      <div class="v-pastille"><i style="background:${ch.hex}"></i>Résonne au chakra ${ch.nom}</div>
      ${p.famille?`<div class="v-notes">${p.famille}</div>`:''}
      <div class="v-pourquoi">${p.pourquoi||''}</div>
      ${blocCompat}
      ${blocMoments}
      ${blocOracle}
      <div class="cta-bloc">
        <div class="cta-txt">${haut
          ? "Envie de savoir s'il est fait pour <b>ton</b> énergie ?"
          : "Envie de trouver le parfum qui vibre vraiment pour <b>toi</b> ?"}</div>
        <a class="bouton-cta" href="${LIEN_DIS_MOI}" target="_blank" rel="noopener">✦ Dis-moi quel parfum tu portes ✦</a>
        <div style="text-align:center;font-size:12.5px;font-style:italic;opacity:.6;margin-top:12px">mesuré par Tanika ✦ Nossane</div>
      </div>
    </div>`;
  $('#verdict').classList.add('visible');
  $('#verdict').scrollIntoView({behavior:'smooth',block:'nearest'});
  enregistrerDansBibliotheque(p);
}

function chercherParNom(q){
  q=q.trim().toLowerCase();
  if(!q) return;
  const p = repertoire().find(x=>(x.nom+' '+x.marque).toLowerCase().includes(q));
  if(p){ afficherVerdict(p); }
  else{ montrerNonTrouve(q); }
}
function chercherParCode(code){
  const p = repertoire().find(x=>x.code && String(x.code)===String(code));
  if(p){ afficherVerdict(p); return true; }
  return false;
}
function montrerNonTrouve(terme){
  $('#verdict').classList.remove('visible');
  $('#non-trouve').innerHTML = `« ${terme} » n'est pas encore dans le répertoire.<br>Ajoute-le depuis le Classeur, ou propose-le à Nossane. ✦`;
  $('#non-trouve').classList.add('visible');
}

